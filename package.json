{
  "name": "graffit-theme",
  "private": true,
  "version": "0.1.0",
  "description": "WordPress theme workflow for GraffiT",
  "scripts": {
    "dev": "sass --watch assets/scss/main.scss:assets/css/main.css --style=expanded",
    "build": "sass assets/scss/main.scss:assets/css/main.css --style=compressed",
    "slice:home-film": "bash scripts/slice-home-film.sh",
    "import:home-film": "bash scripts/import-home-film-webp.sh"
  },
  "devDependencies": {
    "sass": "^1.93.0"
  }
}

